{
  "manifest_version": 3,
  "name": "Pro Image Collector",
  "version": "8.0",
  "description": "Extract, filter, edit, and bulk-download images plus direct public video URLs. Supports WebP conversion, ZIP, Lens, and TinEye.",
  "permissions": ["activeTab", "scripting", "downloads", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}
